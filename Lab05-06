   /*
    * Return the List of top 3 highest (final) score competitors for the given round
    * [Be careful] To get gold medal, you have to be in top 3 and also has a final score above 8.0   
    */
	public List<Competitor> getGoldMedal(List<Competitor> competitors, int round){
		//TODO: Code HERE
		List<Competitor> result = new ArrayList<>();
		List<Competitor> temp = new ArrayList<>();

		for(Competitor c : competitors){
			if(c.getFinalScore(round) >= 8.0){
				temp.add(c);
			}
		}

		for(int k = 0; k < 3 && temp.size() > 0; k++){

			double max = -1;
			int index = -1;

			for(int i = 0; i < temp.size(); i++){
				double score = temp.get(i).getFinalScore(round);

				if(score > max){
					max = score;
					index = i;
				}
			}

			if(index != -1){
				result.add(temp.get(index));
				temp.remove(index);
			}
		}

        return result;
        
	}
	
    public void addCompetitor(Competitor c) {
    	if(!competitors.contains(c))
    		competitors.add(c);
    }
	
	
